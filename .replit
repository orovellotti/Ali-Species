modules = ["nodejs-24", "javascript", "postgresql-16", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "oxigraph-server"

[[workflows.workflow]]
name = "oxigraph-server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "/nix/store/67k2qbsx90k0059d671r8ynx8qhy6i5x-oxigraph-0.3.20/bin/oxigraph_server serve-read-only -l /home/runner/workspace/exports/oxigraph-store --bind 0.0.0.0:9000"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 8083
externalPort = 5173

[[ports]]
localPort = 9000
externalPort = 9000

[[ports]]
localPort = 18514
externalPort = 3000

[[ports]]
localPort = 18515
externalPort = 3003

[[ports]]
localPort = 18516
externalPort = 3001
